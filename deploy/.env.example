# =============================================================================
# BSGateway Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git!
# =============================================================================

# ── LiteLLM Gateway ────────────────────────────────────────────
LITELLM_MASTER_KEY=<generate-with-openssl-rand-hex-32>

# ── Local LLM (Ollama or compatible) ───────────────────────────
LOCAL_LLM_API_BASE=http://host.docker.internal:11434

# ── LLM Providers ──────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── Infrastructure: PostgreSQL ─────────────────────────────────
POSTGRES_USER=bsgateway
POSTGRES_PASSWORD=<choose-a-strong-password>
POSTGRES_DB=bsgateway
COLLECTOR_DATABASE_URL=postgresql://bsgateway:<password>@postgres:5432/bsgateway

# ── Infrastructure: Redis ──────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Authentication (BSVibe-Auth) ──────────────────────────────
# BSVibe Auth URL (default: https://auth.bsvibe.dev — only override for self-hosted)
BSVIBE_AUTH_URL=https://auth.bsvibe.dev
ENCRYPTION_KEY=<64-hex-chars-generate-with-openssl-rand-hex-32>

# ── Server ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=
