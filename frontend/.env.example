# Backend API origin (no trailing slash).
# - Dev: leave empty or set to /api/v1 (Vite proxy forwards to localhost:8000)
# - Prod: set to the backend origin, e.g. https://api-gateway.bsvibe.dev
#   The path prefix /api/v1 is appended automatically if not already present.
VITE_API_URL=

# BSVibe Auth app URL
VITE_AUTH_URL=https://auth.bsvibe.dev

# Allowed hosts for Vite dev server (comma-separated, defaults to all)
VITE_ALLOWED_HOSTS=localhost,127.0.0.1,bsserver
