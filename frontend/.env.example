# Backend API origin (no trailing slash).
# - Dev: leave empty (Next.js rewrites /api/* to NEXT_PUBLIC_API_URL or localhost:8000)
# - Prod: set to the backend origin, e.g. https://api-gateway.bsvibe.dev
#   The path prefix /api/v1 is appended automatically by src/api/client.ts.
NEXT_PUBLIC_API_URL=

# BSVibe Auth app URL
NEXT_PUBLIC_AUTH_URL=https://auth.bsvibe.dev
