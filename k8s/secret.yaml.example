# TEMPLATE: Copy to secret.yaml and fill in real values.
# DO NOT commit secret.yaml — it is gitignored.
apiVersion: v1
kind: Secret
metadata:
  name: bsgateway-secrets
  namespace: bsgateway
type: Opaque
stringData:
  # PostgreSQL
  POSTGRES_USER: bsgateway-prod
  POSTGRES_PASSWORD: ""  # Use a strong, randomly generated password
  
  # Redis
  REDIS_PASSWORD: ""  # Use a strong, randomly generated password

  # JWT (min 32 chars)
  JWT_SECRET: ""

  # Encryption (64 hex chars = 32 bytes for AES-256-GCM)
  ENCRYPTION_KEY: ""

  # Superadmin
  SUPERADMIN_KEY: ""

  # LiteLLM Master Key
  LITELLM_MASTER_KEY: ""
  
  # API Keys
  OPENAI_API_KEY: ""
  ANTHROPIC_API_KEY: ""
