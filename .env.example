# === LiteLLM Gateway ===
LITELLM_MASTER_KEY=sk-change-me-to-a-secure-key

# === Local LLM (Ollama or compatible, referenced by gateway.yaml) ===
LOCAL_LLM_API_BASE=http://host.docker.internal:11434

# === OpenAI ===
OPENAI_API_KEY=

# === Anthropic ===
ANTHROPIC_API_KEY=

# === Database (PostgreSQL for usage tracking) ===
POSTGRES_USER=bsgateway
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=bsgateway
COLLECTOR_DATABASE_URL=postgresql://bsgateway:devpassword@postgres:5432/bsgateway

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# === BSGateway API ===
JWT_SECRET=dev-jwt-secret-change-in-production
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SUPERADMIN_KEY=superadmin-dev-key

# === CORS (comma-separated origins; defaults to http://localhost:{API_PORT}) ===
CORS_ALLOWED_ORIGINS=

# === Frontend ===
# Absolute path to frontend dist/ directory (leave empty for default auto-detection)
FRONTEND_DIST_DIR=
VITE_ALLOWED_HOSTS=bsserver

# === Development Seed Data ===
# Set to true to auto-create a test tenant + API key on startup.
# The generated API key is printed to logs once — save it.
SEED_DEV_DATA=true
