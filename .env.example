# BSGateway environment template.
#
# Copy to `.env` and fill in real values. `.env` is gitignored — do
# NOT commit secrets. Vendor keys must be rotated in the provider
# dashboards before this template is bound to a live deployment
# (Sprint 0 / Lockin §7 user actions).

# === LiteLLM Gateway ===
# Generate fresh: openssl rand -hex 32
LITELLM_MASTER_KEY=

# === Local LLM (Ollama or compatible, referenced by gateway.yaml) ===
LOCAL_LLM_API_BASE=http://host.docker.internal:11434

# === OpenAI === (rotate in dashboard before deploy)
OPENAI_API_KEY=

# === Anthropic === (rotate in dashboard before deploy)
ANTHROPIC_API_KEY=

# === Database (PostgreSQL for usage tracking) ===
POSTGRES_USER=bsgateway
# Strong password — never reuse across environments. Generate fresh:
# openssl rand -base64 32
POSTGRES_PASSWORD=
POSTGRES_DB=bsgateway
# Full DSN; substitute the password above (no plaintext fallback in
# code — bsgateway/api/app.py refuses to start if this is unset).
COLLECTOR_DATABASE_URL=postgresql://bsgateway:<password>@postgres:5432/bsgateway

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
# Required for production. Generate fresh: openssl rand -hex 32
REDIS_PASSWORD=

# === BSGateway API ===
# BSVibe Auth URL (default: https://auth.bsvibe.dev — only override for self-hosted)
BSVIBE_AUTH_URL=https://auth.bsvibe.dev
# AES-256-GCM encryption key (64 hex chars = 32 bytes).
# Generate fresh: openssl rand -hex 32
# Required at startup (`bsgateway.core.config.Settings.encryption_key_bytes`
# raises RuntimeError if blank).
ENCRYPTION_KEY=

# === Server ===
API_HOST=0.0.0.0
# NOTE: Port changed from 4000 to 8000 in the dashboard release.
# Update load balancers, scripts, and documentation accordingly.
API_PORT=8000
LOG_LEVEL=INFO

# === CORS (comma-separated origins; defaults to http://localhost:{API_PORT}) ===
# Leave empty for localhost default. For production, set explicitly:
# CORS_ALLOWED_ORIGINS=https://dashboard.example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=

# === Frontend ===
# Absolute path to frontend dist/ directory (leave empty for default auto-detection)
FRONTEND_DIST_DIR=
VITE_ALLOWED_HOSTS=bsserver

# === BSVibe Authz (Phase 0 P0.5) ===
# Required by bsvibe-authz `Settings` (https://github.com/BSVibe/bsvibe-python).
# OpenFGA — single-node Mac mini deployment from P0.3.
OPENFGA_API_URL=
OPENFGA_STORE_ID=
OPENFGA_AUTH_MODEL_ID=
OPENFGA_AUTH_TOKEN=
# HS256 secret shared with BSVibe-Auth's /api/service-tokens/issue endpoint.
SERVICE_TOKEN_SIGNING_SECRET=
# User session JWT verification (HS256 in Phase 0; JWKS in P0.4-후속).
USER_JWT_SECRET=
USER_JWT_ALGORITHM=HS256
USER_JWT_AUDIENCE=bsvibe
USER_JWT_ISSUER=https://auth.bsvibe.dev

# === BSGateway → BSupervisor precheck (Phase 0 P0.7) ===
# Long-lived BSVibe-Auth user access token for a service-account user
# (admin/owner of BSVIBE_SERVICE_ACCOUNT_TENANT_ID). BSGateway swaps it for
# short-lived service JWTs at startup. Rotate quarterly.
BSVIBE_SERVICE_ACCOUNT_TOKEN=
BSVIBE_SERVICE_ACCOUNT_TENANT_ID=

# BSupervisor base URL (e.g. https://api-supervisor.bsvibe.dev).
BSUPERVISOR_URL=
# Set to true to enable the run.pre/run.post precheck flow. Off by default
# so BSGateway keeps working when BSupervisor is down (matches BSNexus's
# pre-cutover Noop fallback).
BSUPERVISOR_AUDIT_ENABLED=false
BSUPERVISOR_AUDIT_TIMEOUT_MS=200
# "open" → fail-open on timeout (default); "closed" → block runs when
# BSupervisor is unreachable.
BSUPERVISOR_AUDIT_FAIL_MODE=open
