# === LiteLLM Gateway ===
LITELLM_MASTER_KEY=<generate-with-openssl-rand-hex-32>

# === Local LLM (Ollama or compatible, referenced by gateway.yaml) ===
LOCAL_LLM_API_BASE=http://host.docker.internal:11434

# === OpenAI ===
OPENAI_API_KEY=<your-openai-api-key>

# === Anthropic ===
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# === Database (PostgreSQL for usage tracking) ===
POSTGRES_USER=bsgateway
POSTGRES_PASSWORD=<choose-a-strong-password>
POSTGRES_DB=bsgateway
COLLECTOR_DATABASE_URL=postgresql://bsgateway:<password>@postgres:5432/bsgateway

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme-dev

# === BSGateway API ===
# JWT signing secret (min 32 chars, generate with: openssl rand -hex 32)
JWT_SECRET=<generate-with-openssl-rand-hex-32>
# AES-256-GCM encryption key (64 hex chars = 32 bytes, generate with: openssl rand -hex 32)
ENCRYPTION_KEY=<64-hex-chars-generate-with-openssl-rand-hex-32>
# Superadmin bootstrap key (generate with: openssl rand -hex 24)
SUPERADMIN_KEY=<generate-with-openssl-rand-hex-24>

# === Server ===
API_HOST=0.0.0.0
# NOTE: Port changed from 4000 to 8000 in the dashboard release.
# Update load balancers, scripts, and documentation accordingly.
API_PORT=8000
LOG_LEVEL=INFO

# === CORS (comma-separated origins; defaults to http://localhost:{API_PORT}) ===
# Leave empty for localhost default. For production, set explicitly:
# CORS_ALLOWED_ORIGINS=https://dashboard.example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=

# === Frontend ===
# Absolute path to frontend dist/ directory (leave empty for default auto-detection)
FRONTEND_DIST_DIR=
VITE_ALLOWED_HOSTS=bsserver

# === Development Seed Data ===
# Set to true to auto-create a test tenant + API key on startup.
# The generated API key is printed to logs once — save it.
SEED_DEV_DATA=false
